# BTP Conecta — Proteção do diretório do tema

# Desabilita listagem de diretórios
Options -Indexes

# Bloqueia acesso direto a arquivos de documentação interna
<FilesMatch "\.(md|txt|sql|log|sh|bak|orig|DS_Store)$">
    Require all denied
</FilesMatch>

# Bloqueia acesso HTTP direto a arquivos PHP do tema
# (WordPress os carrega via include interno, não via HTTP)
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>
